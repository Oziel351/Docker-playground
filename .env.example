# GHCR image (used to pull prebuilt images instead of building from context)
IMAGE_OWNER_LC=your-github-username
IMAGE_TAG=latest

# Node.js Backend
NODE_ENV=production
BACKEND_PORT=4000

# PostgreSQL Database
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=production-pass
POSTGRES_DB=db

# Redis Cache
REDIS_PORT=6379
REDIS_DB=0
